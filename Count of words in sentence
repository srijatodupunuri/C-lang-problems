#include <stdio.h>
#include <string.h>

int main() {
      char sent[200];
      int count=0;
      printf("\n Enter any sentence: ");
      fgets(sent,sizeof (sent), stdin);
      
      for (int i = 0; sent[i] != '\0'; i++) {
          if (sent[i] == ' '){
            count++;
          }
       }
      int s= count+1;
      printf("%d", s);
      return 0;
}
