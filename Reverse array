#include <stdio.h>

int main() {
    int array[10];
    for(int i=0;i<5;i++){
       printf("Enter element:");
       scanf("%d",&array[i]);
    }
    printf("Array elements are: ");
    for(int i=0;i<5;i++){
        printf("%d\t",array[i]);
    }
    printf("\nReverse Array elements are: ");
    for(int i=4;i>=0;i--){
        printf("%d\t",array[i]);
    }
    
    return 0;
}
