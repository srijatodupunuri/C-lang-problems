#include <stdio.h>

int main() {
    int array[10],arr[10],count=0;
    for(int i=0;i<5;i++){
       printf("Enter element:");
       scanf("%d",&array[i]);
    }
    for(int i=0;i<5;i++){
      for(int j=i+1;j<5;j++){
        if(array[i]==array[j]){
            count++;
        }
      }
    }printf("Duplicate elements count is %d",count);
    return 0;
}
