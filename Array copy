#include <stdio.h>

int main() {
    int array[10],arr[10],sum=0;
    for(int i=0;i<5;i++){
       printf("Enter element:");
       scanf("%d",&array[i]);
    }
    printf("Array elements are: ");
    for(int i=0;i<5;i++){
        printf("%d\t",array[i]);
    }
    printf("\nCopied array elements: ");
    for(int i=0;i<5;i++){
        arr[i]=array[i];
        printf("%d\t",arr[i]);
    }
    return 0;
}
