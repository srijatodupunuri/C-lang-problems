#include <stdio.h>

int main() {
    int a1[100],a2[100],a3[100],i,j,n,m,k,s1,s2,s3;
    printf("Enter no of a1 elements:");
    scanf("%d",&s1);
    printf("Enter elements: ");
    for( int i=0;i<s1;i++){
        scanf("%d",&a1[i]);
        a3[i]=a1[i];
    }
    printf("Enter no of a2 elements:");
    scanf("%d",&s2);
    printf("Enter elements: ");
    for( int i=0;i<s2;i++){
        scanf("%d",&a2[i]);
        a3[i+1]=a2[i];
    }
    s3=s1+s2;
    for(int i=0;i<s3;i++){
        for(int k=0;k<s3-1;k++){
            if(a3[k]<=a3[k+1]){
                j=a3[k+1];
                a3[k+1]=a3[k];
                a3[k]=j;
            }
        }
    }
 
    for(int i=0;i<s3;i++){
        printf("%d",a3[i]);
    }printf("\n");
return 0;
}
