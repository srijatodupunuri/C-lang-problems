#include <stdio.h>

int main() {
    int arr[] = {2, 2, 3, 4, 5, 2};
    int l = 6, prod;
    int left, right;

    for (int i = 0; i < l; i++) {
        if (i == 0) {
            left = arr[i];           
        } else {
            left = arr[i - 1];
        }
        if (i == l - 1) {
            right = arr[i];          
        } else {
            right = arr[i + 1];
        }

        prod = left * right;
        printf("%d\n", prod);
    }

    return 0;
}
