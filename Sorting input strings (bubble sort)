#include <stdio.h>
#include <string.h>

int main() {
    char name[25][50], temp[25]; 
    int n, i, j;
    printf("Input number of strings: ");
    scanf("%d", &n); // Read the number of strings from the user

    printf("Input string %d :\n", n);
    for (i = 0; i <= n; i++) {
        fgets(name[i], sizeof(name[i]), stdin); // Read strings from the user
    }

    /* Logic for Bubble Sort */
    for (i = 1; i <= n; i++) {
        for (j = 0; j <= n - i; j++) {
            if (strcmp(name[j], name[j + 1]) > 0) { // Compare adjacent strings
                strcpy(temp, name[j]); 
                strcpy(name[j], name[j + 1]);
                strcpy(name[j + 1], temp);
            }
        }
    }

    printf("The strings appear after sorting:\n"); 
    for (i = 0; i <= n; i++) {
        printf("%s\n", name[i]);
		
	return 0; 
    }
}
