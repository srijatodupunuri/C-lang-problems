#include <stdio.h>
#include <string.h>

void swap(char *a, char *b) {
    char temp = *a;
    *a = *b;
    *b = temp;
}

void permute(char *str, int st, int en) {
    if (st == en) {
        printf("%s  ", str);
        return;
    }

    for (int i = st; i <= en; i++) {
        swap((str + st), (str + i));   // fix one character at position l
        permute(str, st + 1, en);       // recurse for remaining string
        swap((str + st), (str + i));   // backtrack — restore original order
    }
}

int main() {
    char str[] = "srija";
    int n = strlen(str);

    printf("The permutations of the string are :\n");
    permute(str, 0, n - 1);
    printf("\n");

    return 0;
}
