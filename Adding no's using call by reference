#include <stdio.h>
int sump(int *m,int *n);

int main()
{
    int m ,n,sum;
    printf("Enter m :");
    scanf("%d",&m);
    printf("Enter n :");
    scanf("%d",&n);
    sum=sump(&m,&n);
    printf("the sum of %d and %d is %d",m,n,sum);
    return 0;  
}
int sump(int *m,int *n){
    int sum;
    sum=*m + *n;
    return sum;
}
