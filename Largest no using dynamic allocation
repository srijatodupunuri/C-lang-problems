#include <stdio.h>
#include <string.h>
#include <stdlib.h>

int main(){
    int n,*ptr;
    ptr=(int*)calloc(n,sizeof(int));
    printf("Enter nos : ");
    scanf("%d",&n);
    if(ptr==NULL){
        printf("No memory allocated");
        exit(0);
    }
    printf("\n");
    for(int i=0;i<n;i++){
        printf("Number %d: ",i);
        scanf("%d",ptr+i);
    }
    for(int i=0;i<n;i++){
        if(*ptr<*(ptr+i)){
            *ptr=*(ptr+i);
        }
    }
    printf("The largest no is: %d",*ptr);
    
    return 0;
}
