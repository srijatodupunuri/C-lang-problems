#include <stdio.h>
#include <string.h>

int main() {
    char str[200];
    int freq[256] = {0};
    printf("Enter a sentence: ");
    fgets(str, sizeof(str), stdin);
    for (int i = 0; str[i] != '\0' && str[i] != '\n'; i++) {
        freq[(int)str[i]]++;
    }
    int max = 0;
    char maxChar;
    for (int i = 0; i < 256; i++) {
        if (freq[i] > max && i!=32) { // ascii of space is 32 so spaces are excluded
            max = freq[i];
            maxChar = (char)i;
        }
    }
    printf("Max character : %c | Count : %d\n", maxChar, max);
    return 0;
}
